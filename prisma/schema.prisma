// ============================================================
//  MedSara - Prisma Schema
//  Multi-tenant medical SaaS for Dra. Stéfanny Medrano
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  IN_PERSON
  TELECONSULT
  HOME_VISIT
  EMERGENCY
  FOLLOW_UP
}

enum BloodType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
  UNKNOWN
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

// ─── Doctor ─────────────────────────────────────────────────

model Doctor {
  id        String   @id @default(cuid())
  slug      String   @unique // URL-friendly identifier
  name      String
  specialty String
  email     String   @unique
  phone     String?
  plan      Plan     @default(FREE)
  active    Boolean  @default(true)
  avatarUrl String?
  bio       String?
  address   String?
  whatsapp  String?
  schedules String?  // legacy free-text (kept for backwards compat)
  services  String?
  appointmentDuration Int @default(30) // minutes per slot

  // Supabase auth user ID
  authId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patients               Patient[]
  appointments           Appointment[]
  medicalRecords         MedicalRecord[]
  prescriptions          Prescription[]
  saraConversations      SaraConversation[]
  reminders              Reminder[]
  socialPosts            SocialPost[]
  knowledgeDocuments     KnowledgeDocument[]
  availabilitySchedules  AvailabilitySchedule[]

  @@index([slug])
  @@index([email])
}

// ─── Availability Schedule ───────────────────────────────────

model AvailabilitySchedule {
  id        String  @id @default(cuid())
  doctorId  String
  weekday   Int     // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat
  startTime String  // "09:00"
  endTime   String  // "17:00"
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, weekday])
  @@index([doctorId])
}

// ─── Patient ────────────────────────────────────────────────

model Patient {
  id         String    @id @default(cuid())
  doctorId   String
  name       String
  email      String?
  phone      String?
  birthDate  DateTime?
  bloodType  BloodType @default(UNKNOWN)
  allergies  String[]
  notes      String?
  avatarUrl  String?

  // Identity
  documentId   String? // cédula / passport
  documentType String? // cedula, pasaporte, ruc

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctor            Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  medicalRecords    MedicalRecord[]
  prescriptions     Prescription[]
  saraConversations SaraConversation[]

  @@index([doctorId])
  @@index([email])
  @@index([doctorId, name])
}

// ─── Appointment ────────────────────────────────────────────

model Appointment {
  id        String            @id @default(cuid())
  doctorId  String
  patientId String
  date      DateTime
  duration  Int               @default(30) // minutes
  status    AppointmentStatus @default(SCHEDULED)
  type      AppointmentType   @default(IN_PERSON)
  notes     String?
  reason    String?
  location  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([patientId])
  @@index([doctorId, date])
  @@index([status])
}

// ─── Medical Record ─────────────────────────────────────────

model MedicalRecord {
  id          String   @id @default(cuid())
  patientId   String
  doctorId    String
  diagnosis   String
  treatment   String?
  notes       String?
  symptoms    String[]
  vitalSigns  Json?    // { bp: "120/80", hr: 72, temp: 36.5, weight: 70, height: 170 }
  attachments String[] // URLs to files in Supabase Storage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@index([createdAt])
}

// ─── Prescription ───────────────────────────────────────────

model Prescription {
  id           String   @id @default(cuid())
  patientId    String
  doctorId     String
  date         DateTime @default(now())
  medications  Json     // [{ name, dose, frequency, duration, notes }]
  instructions String?
  diagnosis    String?
  issuedAt     DateTime @default(now())
  expiresAt    DateTime?
  pdfUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@index([date])
}

// ─── Sara Conversation ──────────────────────────────────────

model SaraConversation {
  id        String   @id @default(cuid())
  doctorId  String
  patientId String?  // null if conversation is general (not about a specific patient)
  messages  Json     // [{ role: "user"|"assistant", content: string, timestamp: string }]
  context   String?  // Additional context (e.g., current patient, action being performed)
  title     String?  // Auto-generated conversation title

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctor  Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId])
  @@index([patientId])
  @@index([doctorId, createdAt])
}

// ─── Reminder ───────────────────────────────────────────────

model Reminder {
  id          String   @id @default(cuid())
  doctorId    String
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  completedAt DateTime?
  priority    String   @default("MEDIUM") // LOW | MEDIUM | HIGH
  category    String?  // "patient", "admin", "personal", etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([doctorId, dueDate])
  @@index([completed])
}

// ─── Knowledge Document ─────────────────────────────────────

model KnowledgeDocument {
  id          String   @id @default(cuid())
  doctorId    String
  name        String   // Original file name
  size        Int      // File size in bytes
  mimeType    String   // e.g. "application/pdf"
  storagePath String   // Path in Supabase Storage
  textContent String   @db.Text // Extracted text for semantic search
  createdAt   DateTime @default(now())

  // Relations
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([doctorId, createdAt])
}

// ─── Social Post ────────────────────────────────────────────

model SocialPost {
  id          String     @id @default(cuid())
  doctorId    String
  content     String
  imageUrl    String?
  platforms   Json       // ["instagram", "facebook", "tiktok"]
  publishedAt DateTime?
  scheduledAt DateTime?
  status      PostStatus @default(DRAFT)
  hashtags    String[]
  externalIds Json?      // { instagram: "...", facebook: "..." }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([status])
  @@index([publishedAt])
}
